# Default mode for paper reproduction. Uses the released LLM feature cache and
# does not call any paid LLM API.
NWS_LLM_FEATURE_MODE=cache

# Optional: only needed if you intentionally rebuild the LLM weather-feature
# cache from raw NWS text instead of using the released cache.
NWS_LLM_PROVIDER=deepseek
NWS_LLM_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
